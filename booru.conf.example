# BooruSwipe Configuration
# Copy this file to booru.conf and fill in your values

# LLM Configuration (required for preference learning)
api_key=
base_url=https://api.openai.com/v1
model=

# Booru Source (danbooru or gelbooru)
BOORU_SOURCE=danbooru

# Danbooru API (optional - works without credentials)
danbooru_api_key=
danbooru_user_id=

# Gelbooru API (optional - works without credentials)
gelbooru_api_key=
gelbooru_user_id=

# Advanced Settings (optional - defaults shown)
# LLM_MIN_SWIPES=5
# LLM_MAX_TAGS=100
# LLM_TAG_FILTER_MIN_COUNT=1
# LLM_USE_STRUCTURED_OUTPUT=true
# BOORU_TAGS_PER_SEARCH=2
# BOORU_TAGS_PER_SEARCH_FALLBACK=2
# RANDOM_IMAGE_CHANCE=10
# DOUBLE_LIKED_NEVER_IGNORE=true

# Search Pagination Settings (optional - defaults shown)
# BOORU_SEARCH_LIMIT=100        # Max images per page (max 100)
# BOORU_SEARCH_PAGES=5          # Number of pages to try before giving up
# BOORU_SEARCH_SLEEP=0.15       # Sleep between page requests (seconds)

# BooruSwipe Configuration
# Copy this file to booru.conf and fill in your values

# LLM Configuration (required for preference learning)
api_key=
base_url=https://api.openai.com/v1
model=

# Booru Source (gelbooru, danbooru, or e621)
BOORU_SOURCE=gelbooru

# Danbooru API
danbooru_api_key=
danbooru_user_id=

# Gelbooru API
gelbooru_api_key=
gelbooru_user_id=

# e621 API
e621_api_key=
e621_user_id=

# Advanced Settings (optional - defaults shown)
# LLM_MIN_SWIPES=10
# LLM_MAX_TAGS=30
# LLM_TAG_FILTER_MIN_COUNT=1
# LLM_USE_STRUCTURED_OUTPUT=true
# LLM_RECENT_POSITIVE=10      # Top positive recent tags to send to LLM
# LLM_RECENT_NEGATIVE=10      # Top negative recent tags to send to LLM
# LLM_RECENT_FILTER_CUMULATIVE_LIKES=true
# BOORU_TAGS_PER_SEARCH=5
# BOORU_TAGS_PER_SEARCH_FALLBACK=3
# BOORU_SEARCH_SORT_MODE=score       # Normal search sort mode: score or random
# TAG_DECAY_HALF_LIFE_SWIPES=30  # Half-life in swipes for tag score decay used by ranking and LLM input
# RANDOM_IMAGE_CHANCE=5
# DOUBLE_LIKED_NEVER_IGNORE=false

# Search Pagination Settings (optional - defaults shown)
# BOORU_SEARCH_LIMIT=100        # Max images per page (max 100)
# BOORU_SEARCH_PAGES=3          # Number of pages to try before giving up
# BOORU_SEARCH_SLEEP=0.15       # Sleep between page requests (seconds)
